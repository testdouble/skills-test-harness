{
  "plugins": ["r-and-d"],
  "tests": [
    {
      "name": "Prompt: /investigate",
      "type": "skill-prompt",
      "promptFile": "prompt-investigate.md",
      "model": "opus",
      "scaffold": "ruby-project",
      "expect": [
        { "result-contains": "Root Cause" },
        { "skill-call": { "skill": "r-and-d:investigate", "expected": true } }
      ]
    },
    {
      "name": "Prompt: no op",
      "type": "skill-prompt",
      "model": "sonnet",
      "promptFile": "prompt-no-op.md",
      "expect": [
        { "result-does-not-contain": "Root Cause" },
        { "skill-call": { "skill": "r-and-d:investigate", "expected": false } }
      ]
    },
    {
      "name": "Skill Call: /investigate",
      "type": "skill-call",
      "model": "opus",
      "skillFile": "r-and-d:investigate",
      "promptFile": "skill-call-investigate.md",
      "scaffold": "ruby-project",
      "expect": [
        { "skill-call": true }
      ]
    },
    {
      "name": "Skill Call: no investigate",
      "type": "skill-call",
      "model": "sonnet",
      "skillFile": "r-and-d:investigate",
      "promptFile": "skill-call-no-investigate.md",
      "scaffold": "ruby-project",
      "expect": [
        { "skill-call": false }
      ]
    }
  ]
}
