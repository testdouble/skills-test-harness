{
  "plugins": ["r-and-d"],
  "tests": [
    {
      "name": "Prompt: /code-review simple ruby file",
      "type": "skill-prompt",
      "promptFile": "prompt-code-review.md",
      "model": "opus",
      "scaffold": "ruby-project",
      "expect": [
        { "result-contains": "# Code Review:" },
        { "skill-call": { "skill": "r-and-d:code-review", "expected": true } },
        { "llm-judge": { "rubricFile": "code-review-quality.md", "model": "opus", "threshold": 0.8 } }
      ]
    },
    {
      "name": "Prompt: /code-review go security scaffold",
      "type": "skill-prompt",
      "promptFile": "prompt-code-review-go-security.md",
      "model": "opus",
      "scaffold": "go-security-project",
      "expect": [
        { "result-contains": "# Code Review:" },
        { "skill-call": { "skill": "r-and-d:code-review", "expected": true } },
        { "llm-judge": { "rubricFile": "code-review-security-quality.md", "model": "opus", "threshold": 0.8 } }
      ]
    },
    {
      "name": "Prompt: no op",
      "type": "skill-prompt",
      "model": "sonnet",
      "promptFile": "prompt-no-op.md",
      "expect": [
        { "result-does-not-contain": "# Code Review:" },
        { "skill-call": { "skill": "r-and-d:code-review", "expected": false } }
      ]
    },
    {
      "name": "Skill Call: /code-review",
      "type": "skill-call",
      "model": "opus",
      "skillFile": "r-and-d:code-review",
      "promptFile": "skill-call-code-review.md",
      "scaffold": "ruby-project",
      "expect": [
        { "skill-call": true }
      ]
    },
    {
      "name": "Skill Call: don't include the word 'review'",
      "type": "skill-call",
      "promptFile": "skill-call-lack-of-word.md",
      "skillFile": "r-and-d:code-review",
      "model": "opus",
      "scaffold": "ruby-project",
      "expect": [
        { "skill-call": true }
      ]
    },
    {
      "name": "Skill Call: movie review",
      "type": "skill-call",
      "model": "sonnet",
      "skillFile": "r-and-d:code-review",
      "promptFile": "skill-call-movie-review.md",
      "scaffold": "ruby-project",
      "expect": [
        { "skill-call": false }
      ]
    },
    {
      "name": "Skill Call: book review",
      "type": "skill-call",
      "model": "sonnet",
      "skillFile": "r-and-d:code-review",
      "promptFile": "skill-call-book-review.md",
      "scaffold": "ruby-project",
      "expect": [
        { "skill-call": false }
      ]
    },
    {
      "name": "Skill Call: review changes in branch",
      "type": "skill-call",
      "promptFile": "skill-call-review-branch.md",
      "skillFile": "r-and-d:code-review",
      "model": "opus",
      "scaffold": "ruby-project",
      "expect": [
        { "skill-call": true }
      ]
    }
  ]
}
