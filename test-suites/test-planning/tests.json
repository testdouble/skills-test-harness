{
  "plugins": ["r-and-d"],
  "tests": [
    {
      "name": "Prompt: /test-planning",
      "type": "skill-prompt",
      "promptFile": "prompt-test-planning.md",
      "model": "opus",
      "scaffold": "ruby-project",
      "expect": [
        { "result-contains": "Test Plan" },
        { "skill-call": { "skill": "r-and-d:test-planning", "expected": true } }
      ]
    },
    {
      "name": "Prompt: no op",
      "type": "skill-prompt",
      "model": "sonnet",
      "promptFile": "prompt-no-op.md",
      "expect": [
        { "result-does-not-contain": "Test Plan" },
        { "skill-call": { "skill": "r-and-d:test-planning", "expected": false } }
      ]
    },
    {
      "name": "Skill Call: /test-planning",
      "type": "skill-call",
      "model": "opus",
      "skillFile": "r-and-d:test-planning",
      "promptFile": "skill-call-test-planning.md",
      "scaffold": "ruby-project",
      "expect": [
        { "skill-call": true }
      ]
    },
    {
      "name": "Skill Call: no test-planning",
      "type": "skill-call",
      "model": "sonnet",
      "skillFile": "r-and-d:test-planning",
      "promptFile": "skill-call-no-test-planning.md",
      "expect": [
        { "skill-call": false }
      ]
    }
  ]
}
